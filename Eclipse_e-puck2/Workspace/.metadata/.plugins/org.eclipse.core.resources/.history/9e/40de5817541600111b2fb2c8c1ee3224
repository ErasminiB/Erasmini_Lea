int main(void)
{

    halInit();
    chSysInit();
    mpu_init();

    // Proximity
    messagebus_init(&bus, &bus_lock, &bus_condvar);
    proximity_start(0);
    calibrate_ir();

    //LED
    clear_leds();
    spi_comm_start();

    //set_body_led(2);
    //chThdSleepMilliseconds(1000);

    //Motors
    motors_init();
    get_selector();
    int blink_count = 0;

    /* Infinite loop. */
    while (1)
    {
    	if (blink_count < 2*get_selector()){
			left_motor_set_speed(500);
			right_motor_set_speed(-500);
			chThdSleepMilliseconds(1000);
			set_body_led(2);
			blink_count+=1;
    	}

    	else{
    		left_motor_set_speed(-500);
    		right_motor_set_speed(500);
    	}



    	//if (int selector==get_selector());
    			//get_calibrated_prox(0)>=200 || get_calibrated_prox(7)>=200)
    //	{
    	//	set_front_led(2);
